---
const playStoreUrl = "https://play.google.com/store/apps/details?id=com.mbn.hogargo";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>HogarGo | Tareas, planificador, compras y economía compartida del hogar</title>

    <meta
      name="description"
      content="Organiza tareas del hogar, listas de compra, economía compartida y planificación familiar con HogarGo. Disponible para Android."
    />
    <link rel="icon" type="image/png" href="/logoandroid.png" />
  </head>

  <body>
    <main class="hero">
      <section class="heroText">
        <div class="brand">
          <img src="/logoandroid.png" alt="Logo HogarGo" />
          <span>HogarGo</span>
        </div>

        <h1>Todo tu hogar, en una sola app</h1>

        <p>
          Organiza tareas, compras, economía compartida y planificación con tu
          hogar de forma fácil.
        </p>

        <a
  class="download"
  href={playStoreUrl}
  target="_blank"
  rel="noopener noreferrer"
>
  📲 Descargar en Google Play
</a>
      </section>

      <section class="heroImage">
        <img
          class="appPoster"
          src="/presentacion.png"
          alt="Presentación de HogarGo"
        />
      </section>

      <footer>
        <span>© 2026 HogarGo</span>
        <a href="mailto:tuemail@ejemplo.com">Contacto</a>
        <a href="/privacidad">Privacidad</a>
      </footer>
    </main>
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(html) {
    height: 100%;
  }

  body {
    min-height: 100%;
    margin: 0;
    overflow: hidden;
    font-family:
      Inter,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    background:
      radial-gradient(circle at 15% 10%, rgba(53, 182, 255, 0.35), transparent 30%),
      radial-gradient(circle at 85% 15%, rgba(22, 104, 255, 0.25), transparent 28%),
      linear-gradient(135deg, #f5fbff 0%, #eaf6ff 48%, #ffffff 100%);
    color: #07172f;
  }

  .hero {
    height: 100svh;
    display: grid;
    grid-template-columns: 0.72fr 1.28fr;
    grid-template-rows: 1fr auto;
    grid-template-areas:
      "text image"
      "footer footer";
    align-items: center;
    gap: clamp(20px, 3vw, 48px);
    padding: clamp(20px, 4vw, 56px) clamp(20px, 5vw, 80px) 0;
  }

  .heroText {
    grid-area: text;
    max-width: 620px;
    min-width: 0;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: clamp(12px, 2vh, 24px);
    font-size: clamp(24px, 2.3vw, 30px);
    font-weight: 900;
  }

  .brand img {
    width: clamp(52px, 5vw, 64px);
    height: clamp(52px, 5vw, 64px);
    border-radius: 18px;
    box-shadow: 0 16px 32px rgba(0, 119, 255, 0.22);
  }

  .pill {
    display: inline-flex;
    padding: 10px 16px;
    border-radius: 999px;
    background: rgba(0, 119, 255, 0.12);
    color: #005fd1;
    font-weight: 800;
    margin-bottom: clamp(14px, 2vh, 24px);
  }

  h1 {
    margin: 0 0 clamp(14px, 2vh, 24px);
    font-size: clamp(36px, 5vw, 64px);
    line-height: 0.96;
    letter-spacing: -0.055em;
  }

  p {
    margin: 0 0 clamp(20px, 3vh, 34px);
    max-width: 540px;
    font-size: clamp(17px, 1.8vw, 22px);
    line-height: 1.45;
    color: #38506d;
  }

  .download {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 56px;
    padding: 0 28px;
    border-radius: 18px;
    background: linear-gradient(135deg, #008cff, #005cff);
    color: white;
    text-decoration: none;
    font-weight: 900;
    font-size: 18px;
    box-shadow: 0 20px 38px rgba(0, 102, 255, 0.32);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .download:hover {
    transform: translateY(-2px);
    box-shadow: 0 24px 46px rgba(0, 102, 255, 0.4);
  }

.heroImage {
  grid-area: image;
  min-width: 0;

  display: flex;
  align-items: center;
  justify-content: flex-end;

  position: relative;
}

.heroImage::before {
  content: "";
  position: absolute;
  inset: 8%;

  border-radius: 40px;

  background:
    linear-gradient(
      135deg,
      rgba(0, 140, 255, 0.16),
      rgba(255, 255, 255, 0.06)
    );

  filter: blur(45px);
  opacity: 0.85;
  z-index: 0;
}

.appPoster {
  position: relative;
  z-index: 1;

  width: min(100%, 1120px);
  max-height: calc(100svh - 116px);

  display: block;
  object-fit: contain;

  border: none;
  border-radius: 0;

  box-shadow: none;
  filter: none;
}

  footer {
    grid-area: footer;
    min-height: 64px;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    padding: 12px 20px 20px;
    font-weight: 700;
    color: #45617f;
  }

  footer a {
    color: #006dff;
    text-decoration: none;
  }

  @media (max-width: 1000px) {
    body {
      overflow: auto;
    }

    .hero {
      min-height: 100svh;
      height: auto;
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto;
      grid-template-areas:
        "text"
        "image"
        "footer";
      text-align: center;
      gap: 22px;
      padding: 26px 16px 0;
    }

    .heroText {
      max-width: 680px;
      margin-inline: auto;
    }

    .brand {
      justify-content: center;
      margin-bottom: 12px;
    }

    .pill {
      margin-bottom: 14px;
    }

    h1 {
      font-size: clamp(36px, 10vw, 56px);
    }

    p {
      margin-inline: auto;
      font-size: clamp(16px, 4.2vw, 20px);
    }

    .download {
      min-height: 54px;
      width: min(100%, 340px);
    }

    .heroImage {
      justify-content: center;
      width: 100%;
    }

    .appPoster {
      width: min(100%, 680px);
      max-height: none;
      border-radius: 22px;
    }

    footer {
      flex-wrap: wrap;
      min-height: auto;
      padding: 18px 12px 24px;
    }
  }

  @media (max-width: 520px) {
    .hero {
      gap: 18px;
      padding-inline: 12px;
    }

    .brand img {
      width: 48px;
      height: 48px;
    }

    .brand {
      font-size: 24px;
    }

    .pill {
      font-size: 14px;
      padding: 8px 13px;
    }

    h1 {
      font-size: clamp(34px, 11vw, 48px);
    }

    p {
      line-height: 1.35;
      margin-bottom: 18px;
    }

    .appPoster {
      width: 100%;
      border-radius: 32px;
    }
  }
</style>